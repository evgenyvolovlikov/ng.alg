root = true

# --- ГЛОБАЛЬНЫЕ НАСТРОЙКИ ДЛЯ ВСЕХ ТЕКСТОВЫХ ФАЙЛОВ ---
[*]
charset = utf-8
indent_style = tab
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# --- ИСПРАВЛЕНИЕ МАСКИ И КАВЫЧЕК ДЛЯ ВЕБ-ФАЙЛОВ ---
[{*.js,*.ts,*.jsx,*.tsx,*.html,*.scss}]
quote_type = single

# --- СПЕЦИФИКА JSON (Запрещаем одинарные кавычки) ---
[{*.json,*.rc}]
quote_type = double

# --- ФОРМАТИРОВАНИЕ ДОКУМЕНТАЦИИ МАРКДАУН ---
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# --- ЗАЩИТА БИНАРНЫХ ФАЙЛОВ И ЛОКОВ ПАКЕТОВ ОТ ПОВРЕЖДЕНИЯ ---
[{*.png,*.jpg,*.jpeg,*.gif,*.webp,*.ico,*.svg}]
charset = unset
insert_final_newline = false
trim_trailing_whitespace = false

[pnpm-lock.yaml]
insert_final_newline = false
trim_trailing_whitespace = false
